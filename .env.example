# VoiceOrder NLP Backend - Environment Variable Template
# Copy to .env and fill real values. NEVER commit .env.

# Database (Supabase free tier)
DATABASE_URL=postgresql+asyncpg://user:password@db.supabase.co:5432/postgres

# Redis (Upstash free tier)
REDIS_URL=redis://default:password@your-endpoint.upstash.io:6379

# JWT RS256 Keys
# Generate with: bash scripts/generate_keys.sh
# Paste the full PEM content (including -----BEGIN/END----- lines).
# In Railway: set as multi-line env vars in the dashboard.
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
REPLACE_WITH_ACTUAL_PRIVATE_KEY
-----END RSA PRIVATE KEY-----

JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
REPLACE_WITH_ACTUAL_PUBLIC_KEY
-----END PUBLIC KEY-----

# App
# Values: development | production | test
ENVIRONMENT=development

# Token lifetime in hours (24h demo, 1h prod)
ACCESS_TOKEN_EXPIRE_HOURS=24

# Comma-separated - prod: https://voiceorder-demo.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# NLP
SPACY_MODEL=en_core_web_sm
NLP_CONFIDENCE_THRESHOLD=0.6
FUZZY_SCORE_CUTOFF=75
